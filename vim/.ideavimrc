" .ideavimrc is a configuration file for IdeaVim plugin. It uses
"   the same commands as the original .vimrc configuration.
" You can find a list of commands here: https://jb.gg/h38q75
" Find more examples here: https://jb.gg/share-ideavimrc
" --- Enable IdeaVim plugins https://jb.gg/ideavim-plugins
"" -- Map IDE actions to IdeaVim -- https://jb.gg/abva4t

set ideavimsupport=dialog,singleline

nnoremap <SPACE> <Nop>
let mapleader=" "

set scrolloff=5
set incsearch
set relativenumber
set ignorecase
set smartcase

" -- Use system clipboard
set clipboard+=unnamed
set clipboard+=ideaput

"" Map random actions
noremap <Leader>r :action RenameElement<CR>
noremap <leader>t :action Refactorings.QuickListPopupAction<CR>
noremap <leader>q :action CloseContent<CR>
noremap <leader>g :action GotoDeclaration<CR>
noremap <leader>f :action ReformatCode<CR>

"" Map debugger actions
noremap <leader>n :action ConfigurationXDebuggerResumeAction<CR>
noremap <leader>d :action Debug<CR>
noremap <leader>s :action Stop<CR>
noremap <leader>b :action ToggleLineBreakpoint<CR>

"" Map buffer actions
noremap <leader>v :vsp<CR>
noremap <leader>h :sp<CR>
noremap <leader>x :action CloseEditor<CR>
noremap <leader>x <C-w>c
noremap <leader>X :action UnsplitAll<CR>

""
"" -- Togglable paste mode
"" 
let g:paste_no_overwrite = 1

function! TogglePasteMode()
  if g:paste_no_overwrite
    let g:paste_no_overwrite = 0
    vnoremap p p
    echo "Paste mode: DEFAULT (overwrites register)"
  else
    let g:paste_no_overwrite = 1
    vnoremap p "_c<C-r>0<Esc>
    echo "Paste mode: SAFE (preserves register)"
  endif
endfunction

" Default to safe paste
vnoremap p "_c<C-r>0<Esc>
nnoremap <leader>pp :<C-u>call TogglePasteMode()<CR>

""
"" --- Rendered Comments / Documentation ---
""

"" Map <leader>c to toggle rendered comments (reader mode) at the cursor
noremap <leader>c :action ToggleRenderedDocPresentation<CR>

"" Map <leader>C to toggle rendered comments globally for ALL files/comments
noremap <leader>C :action ToggleRenderedDocPresentationForAll<CR>

""
"" --- Comment Folding (File Scope) ---
""

"" Map <leader>zc to collapse all documentation comments in the current file
noremap <leader>zc :action CollapseDocComments<CR>

"" Map <leader>zo to expand all documentation comments in the current file
noremap <leader>zo :action ExpandDocComments<CR>

""
"" --- view quick actions ---
""
noremap <Leader>qd :action QuickJavaDoc<CR>
noremap <Leader>qp :action ParameterInfo<CR>
noremap <Leader>qe :action ShowErrorDescription<CR>

""
"" --- VCS ---
""
noremap <Leader>vr :action Vcs.RollbackChangedLines<CR>
noremap <Leader>vb :action Annotate)

""
"" --- PRs ---
""

noremap <leader>pc :action Code.Review.Editor.New.Comment<CR>

"" PR suggestion workflow

let g:last_sel = {}

function! SaveLastSelection()
  let g:last_sel = {'start': line("'<"), 'stop': line("'>"), 'total': line('$')}
endfunction

function! ReselectSurviving()
  if !exists('g:last_sel') || empty(g:last_sel)
    echo "No saved selection" | return
  endif

  let first = g:last_sel.start
  let gtotal = g:last_sel.total
  let total = line('$')
  let gstop = g:last_sel.stop + (line('$') - gtotal)
  let stop = gstop + (total - total)

  if first > total || stop < first
    echo "Nothing left of the selection" | return
  endif
  if stop > total | let stop = total | endif

  execute "normal! " . first . "GV" . stop . "G"
endfunction

function! ReselectSurvivingForComment()
  if !exists('g:last_sel') || empty(g:last_sel)
    echo "No saved selection" | return
  endif
  
  let first = g:last_sel.start
  let gtotal = g:last_sel.total
  let total = line('$')
  let gstop = g:last_sel.stop + (line('$') - gtotal)
  let stop = gstop + (total - total)

  let first = g:last_sel.start
  if first > total || stop < first
    echo "Nothing left of the selection" | return
  endif
  if stop > total | let stop = total | endif

  if stop > first
    let stop = stop - 1
  endif

  execute "normal! " . first . "GV" . stop . "G"
endfunction

function! WrapAsSuggestion()
  let text = @+
  if text[-1:] == "\n"
    let text = text[:-2]
  endif
  let @+ = "```suggestion\n" . text . "\n```"
endfunction

xnoremap <silent> <leader>ms :<C-u>call SaveLastSelection()<CR>
nnoremap <silent> <leader>mr :<C-u>call ReselectSurviving()<CR>
xnoremap <silent> <leader>ps "+y:<C-u>call WrapAsSuggestion()<CR>:call SaveLastSelection()<CR>:call ReselectSurviving()<CR>:action Vcs.RollbackChangedLines<CR>:call ReselectSurvivingForComment()<CR>:action Code.Review.Editor.New.Comment<CR>
